/**
 * @file Overview
 * This ruleset enforces a user-ownership model for revision logs,
 * ensuring users can only manage their own revision data. All data is stored in top-level collections: `/users/{userId}` and `/revisionLogs/{logId}`.
 *
 * Key Security Decisions:
 * - Users can only list revision logs that they own.
 * - Users can create, update, and delete only their own revision logs.
 * - The 'userId' field in the 'RevisionLog' entity is immutable and must match the authenticated user's ID.
 *
 * Denormalization for Authorization:
 * - The 'RevisionLog' documents contain a 'userId' field to associate each log with its owner. This simplifies authorization checks,
 *   avoiding costly `get()` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects user profiles. Users can only read and write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile.
     *   Request: auth.uid = "user123", resource.data.id = "user123"
     * @allow (get, update, delete) - Authenticated user reads/updates/deletes their own profile.
     *   Request: auth.uid = "user123", resource.data.id = "user123"
     * @deny (create) - Authenticated user attempts to create a profile with a mismatched ID.
     *   Request: auth.uid = "user123", resource.data.id = "user456"
     * @deny (get, update, delete) - Authenticated user attempts to read/update/delete another user's profile.
     *   Request: auth.uid = "user123", resource.data.id = "user456"
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource.data != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages revision logs.  Users can read their own logs.
     * @path /revisionLogs/{logId}
     * @allow (create) - Authenticated user creates a new revision log with their user ID.
     *   Request: auth.uid = "user123", resource.data.userId = "user123"
     * @allow (get, update, delete) - Authenticated user reads/updates/deletes their own revision log.
     *   Request: auth.uid = "user123", resource.data.userId = "user123"
     * @allow (list) - Authenticated user lists their own revision logs.
     *   Request: auth.uid = "user123"
     * @deny (create) - Authenticated user attempts to create a revision log for another user.
     *   Request: auth.uid = "user123", resource.data.userId = "user456"
     * @deny (get, update, delete) - Authenticated user attempts to read/update/delete another user's revision log.
     *   Request: auth.uid = "user123", resource.data.userId = "user456"
     * @principle Enforces document ownership for revision logs.
     */
    match /revisionLogs/{logId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner() {
        return resource.data.userId == request.auth.uid;
      }

      allow get: if isExistingOwner();
      allow list: if request.auth.uid != null;
      allow create: if request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner();
      allow delete: if isExistingOwner();
    }
  }
}