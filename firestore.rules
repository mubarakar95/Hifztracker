/**
 * @description This ruleset enforces a strict user-ownership model for revision logs. Users can only create, read, update, and delete their own revision log entries.
 * @dataStructure Data is nested under /users/{userId}/revisionLogs/{revisionLogId}.
 * @keySecurityDecisions
 *   - Users can only manage revision logs associated with their own user ID.
 *   - Listing of all revision logs across users is disallowed for privacy.
 *   - No global admin roles are defined.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for revision logs. Only the authenticated user can manage their own revision logs.
     * @path /databases/{database}/documents/users/{userId}/revisionLogs/{revisionLogId}
     * @allow (create) User Nf70GCVu43clR4AgCX9k0qzgeTk2 creates a new revision log entry under their user ID.
     * @deny (create) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to create a revision log entry under a different user ID.
     * @allow (get) User Nf70GCVu43clR4AgCX9k0qzgeTk2 retrieves their own revision log entry.
     * @deny (get) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to retrieve a revision log entry belonging to another user.
     * @allow (update) User Nf70GCVu43clR4AgCX9k0qzgeTk2 updates their own revision log entry.
     * @deny (update) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to update a revision log entry belonging to another user.
     * @allow (delete) User Nf70GCVu43clR4AgCX9k0qzgeTk2 deletes their own revision log entry.
     * @deny (delete) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to delete a revision log entry belonging to another user.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/revisionLogs/{revisionLogId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
    
    /**
     * @description Enforces user-ownership for user documents. Only the authenticated user can manage their own user document.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (create) User Nf70GCVu43clR4AgCX9k0qzgeTk2 creates their user document with a matching user ID.
     * @deny (create) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to create a user document with a mismatched user ID.
     * @allow (get) User Nf70GCVu43clR4AgCX9k0qzgeTk2 retrieves their own user document.
     * @deny (get) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to retrieve a user document belonging to another user.
     * @allow (update) User Nf70GCVu43clR4AgCX9k0qzgeTk2 updates their own user document.
     * @deny (update) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to update a user document belonging to another user.
     * @allow (delete) User Nf70GCVu43clR4AgCX9k0qzgeTk2 deletes their own user document.
     * @deny (delete) User Nf70GCVu43clR4AgCX9k0qzgeTk2 attempts to delete a user document belonging to another user.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree. Validates that the user ID in the path matches the document's ID.
     */
     match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}