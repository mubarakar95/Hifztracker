/**
 * @file Firebase Security Rules for Hifz Tracker.
 *
 * @description This ruleset enforces a strict user-ownership model for all data.
 * All user data and revision logs are nested under `/users/{userId}`, ensuring that only the authenticated user can access their own information.
 *
 * @dataStructure
 * - `/users/{userId}`: Stores user profile information.  Accessible only by the user themselves.
 * - `/users/{userId}/revisionLogs/{revisionLogId}`: Stores revision log entries for a specific user.  Accessible only by the user themselves.
 *
 * @keySecurityDecisions
 * - Users can only access their own data.
 * - No user listing is allowed.
 * - All writes are validated against the authenticated user's ID.
 * - Data consistency between the path and document `userId` field is enforced.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     * @allow (get, update, delete) if the user is signed in and the requested userId matches their authentication UID.
     * @allow (create) if the user is signed in and the created document's ID matches their authentication UID.
     * @deny (get, list) if the user is not signed in or the requested userId does not match their authentication UID.
     * @deny (create) if the user is not signed in or the created document's ID does not match their authentication UID.
     * @principle Enforces document ownership for reads and writes, validates userId on creation, and ensures path consistency.
     */
    match /users/{userId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the authenticated user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // No user listing allowed

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id; //Enforce immutability
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to revision log entries for a specific user. Only the authenticated user can access their own revision logs.
     * @path /users/{userId}/revisionLogs/{revisionLogId}
     * @allow (get, list, create, update, delete) if the user is signed in and the requested userId matches their authentication UID.
     * @deny (get, list, create, update, delete) if the user is not signed in or the requested userId does not match their authentication UID.
     * @principle Enforces document ownership for all operations, validates userId on creation, and ensures path consistency.
     */
    match /users/{userId}/revisionLogs/{revisionLogId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the authenticated user is the owner of the document
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the authenticated user is the existing owner of the document
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId; //Enforce immutability
      allow delete: if isExistingOwner(userId);
    }
  }
}