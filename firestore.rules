/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a strict user-ownership model. Each user can only access their own data,
 *  and only authenticated users can create data. Data shapes are not strictly enforced to allow for rapid prototyping.
 * @data_structure All user-related data is nested under `/users/{userId}`. Each user has a subcollection `revisionLogs`.
 * @key_security_decisions Users can only create revision logs under their own user ID.
 *  Listing users is disallowed for privacy.
 * @denormalization For authorization efficiency, the `userId` is denormalized into the `RevisionLog` documents, enabling direct ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user documents.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (read, update) Authenticated user with matching UID can read/update their own document.
     * @deny (read, update) Authenticated user cannot read/update another user's document.
     * @allow (create) Authenticated user can create their own document.
     * @deny (create) Unauthenticated user cannot create any user document.
     * @principle Enforces user ownership: only the authenticated user can access their own profile.
     */
    match /users/{userId} {
      // Helper function to check if the request is from the owner
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allow read and update if the user is signed in and the userId matches the requested userId
      allow read, update: if isOwner(userId);

      // Allow create if the user is signed in and the userId in the path matches the authenticated user's ID.
      // Also validate that the user ID inside the document matches the `userId` in the path.
      allow create: if isOwner(userId) && request.resource.data.id == userId;

      // Protect the user id from being changed after creation.
      allow update: if isOwner(userId) && resource.data.id == userId;

      // Prevent listing of all users
      allow list: if false;

      // Prevent deletion of user accounts
      allow delete: if false;

      /**
       * @description Controls access to revision logs for a specific user.
       * @path /databases/{database}/documents/users/{userId}/revisionLogs/{logId}
       * @allow (create) Authenticated user with matching UID can create a revision log under their user ID.
       * @deny (create) Authenticated user cannot create a revision log under another user's ID.
       * @allow (read, update, delete) Authenticated user with matching UID can read/update/delete their own revision logs.
       * @deny (read, update, delete) Authenticated user cannot read/update/delete revision logs of other users.
       * @principle Enforces ownership: only the authenticated user can access their own revision logs.
       */
      match /revisionLogs/{logId} {
        // Helper function to check if the request is from the owner
        function isOwner(userId) {
          return request.auth != null && request.auth.uid == userId;
        }

        // Allow read, create, update, delete if the user is signed in and the userId matches the requested userId
        allow read, create, update, delete: if isOwner(userId) && request.resource.data.userId == userId;

        // Allow list if the user is signed in and the userId matches the requested userId
        allow list: if isOwner(userId);
      }
    }
  }
}