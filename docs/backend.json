
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Hifz Tracker application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The user's username."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "registrationDate": {
          "type": "string",
          "description": "The date and time the user registered.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "registrationDate"
      ]
    },
    "RevisionLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RevisionLog",
      "type": "object",
      "description": "Represents a single revision log entry for a specific quarter juz (5 pages).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the RevisionLog entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N RevisionLog)"
        },
        "juzPart": {
          "type": "number",
          "description": "The number representing the quarter juz revised (1-120, where each juz is split into 4 parts)"
        },
        "revisionDate": {
          "type": "string",
          "description": "The date of the revision.",
          "format": "date-time"
        },
        "qualityRating": {
          "type": "string",
          "enum": ["Excellent", "Good", "Needs Improvement"],
          "description": "The user's rating of the revision quality."
        },
        "comments": {
          "type": "string",
          "description": "Any comments or notes the user added for this revision."
        }
      },
      "required": [
        "id",
        "userId",
        "juzPart",
        "revisionDate",
        "qualityRating"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profile information."
    },
    "/revisionLogs/{logId}": {
      "schema": {
        "$ref": "#/entities/RevisionLog"
      },
      "description": "Stores all revision logs from all users."
    }
  }
}
